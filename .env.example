# Root .env.example — Combined backend and frontend example
# Copy relevant sections into `backend/.env` and `frontend/.env` respectively.

###########################
# Backend (Node/Express)
###########################
# MongoDB connection string (replace with your URI)
MONGO_URI=mongodb://localhost:27017/palmmind

# JWT secret for signing tokens (change to a secure value)
JWT_SECRET=your_jwt_secret_here

# Server port
PORT=5000

# Client URL (used for CORS / cookie settings)
CLIENT_URL=http://localhost:5173


###########################
# Frontend (Vite / React)
###########################
# API base URL used by the frontend (include /api if applicable)
VITE_API_URL=http://localhost:5000/api

# Socket server URL
VITE_SOCKET_URL=http://localhost:5000

# End of example file
